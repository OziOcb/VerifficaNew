# Local Supabase (npx supabase start) — ACTIVE for local dev.
# Studio: http://127.0.0.1:54323 · Mailpit: http://127.0.0.1:54324
SUPABASE_URL=###
SUPABASE_KEY=###

# Test/local ONLY — used by the Vitest RLS suite (npm test) to seed/teardown
# users via the service_role admin API. service_role bypasses RLS, so this is
# NEVER an app secret and is NEVER added to the astro.config.mjs env schema.
# Get the local value from: npx supabase status -o env (SERVICE_ROLE_KEY).
# SUPABASE_SERVICE_ROLE_KEY=###

# Cloud Supabase — uncomment these (and comment the local pair above) to point
# local dev at the hosted project. Production is unaffected either way.
# SUPABASE_URL=###
# SUPABASE_KEY=###
