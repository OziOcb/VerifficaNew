# Deployed workerd smoke-gate credentials (npm run smoke:deployed).
#
# Copy to `.env.smoke` (gitignored) and fill with PRODUCTION Supabase values —
# the deployed Worker uses prod secrets, so the authenticated rung must create
# its ephemeral, self-cleaning user in the SAME prod project. NEVER commit real
# keys; never point these at local Supabase.

# Prod Supabase project URL.
SUPABASE_URL=

# Prod anon (publishable) key — used to sign the ephemeral user in.
SUPABASE_KEY=

# Prod service-role key — used ONLY to create + cascade-delete the ephemeral
# user. Highly privileged (bypasses RLS); keep it out of git and CI logs.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: override the live Worker URL the smoke targets. Defaults to
# https://veriffica.veriffica.workers.dev when unset.
# SMOKE_URL=
