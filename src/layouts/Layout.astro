---
import "../styles/global.css";
import Banner from "@/components/Banner.astro";
import { missingConfigs } from "@/lib/config-status";
import { resolveTheme, normalizeFontScale } from "@/lib/theme";

interface Props {
  title?: string;
}

const { title = "Veriffica" } = Astro.props;

// Device-local preferences (S-10 / FR-022). Both are cookies the client writes and
// the server only reads. `resolveTheme` returns "light"/"dark" for explicit choices
// and null for `system` (or absent/legacy) — the server can't read the OS scheme, so
// the inline <head> script below resolves `system` via matchMedia before first paint.
// The font scale is fully server-resolvable from its cookie.
const themeClass = resolveTheme(Astro.cookies.get("theme")?.value);
const fontScale = normalizeFontScale(Astro.cookies.get("fontScale")?.value);
---

<!doctype html>
<html lang="en" class:list={themeClass === "dark" ? "dark" : []} data-font-scale={fontScale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0a0e1a" />
    <script is:inline>
      // No-flash guard for the device-local theme + font-scale cookies (S-10).
      // Must stay a blocking inline <head> script (not type="module"/deferred) so it
      // runs before <body> paints. It resolves `system` (and absent/legacy values)
      // via matchMedia — the server cannot — and applies both preferences. The
      // resolution rules here are duplicated verbatim from `@/lib/theme`; keep them
      // in sync (see the note in that module) or SSR and first paint will disagree.
      (function () {
        try {
          var read = function (name) {
            var m = document.cookie.match(new RegExp("(?:^|; )" + name + "=([^;]*)"));
            return m ? decodeURIComponent(m[1]) : undefined;
          };
          var choice = read("theme");
          var isDark =
            choice === "dark" || (choice !== "light" && window.matchMedia("(prefers-color-scheme: dark)").matches);
          document.documentElement.classList.toggle("dark", isDark);
          var scale = read("fontScale");
          if (scale !== "sm" && scale !== "lg") scale = "base";
          document.documentElement.setAttribute("data-font-scale", scale);
        } catch (e) {
          /* cookies/matchMedia unavailable — fall back to server-rendered class */
        }
      })();
    </script>
    <title>{title}</title>
  </head>
  <body>
    {
      missingConfigs.map((cfg) => (
        <Banner variant="error">
          <strong>Note:</strong> {cfg.message}
          {cfg.docsUrl && (
            <>
              {" "}
              <a href={cfg.docsUrl} target="_blank" rel="noopener noreferrer">
                {cfg.docsLabel ?? "Documentation"}
              </a>
              .
            </>
          )}
        </Banner>
      ))
    }
    <slot />
    <script>
      // Live-follow the OS color scheme while the theme choice is `system` (S-10).
      // initSystemFollow() is a no-op for explicit light/dark overrides, so it is
      // safe to register on every page. The no-flash inline <head> script already
      // applied the correct class for first paint; this only handles later changes.
      import { initSystemFollow } from "@/lib/theme";
      initSystemFollow();
    </script>
    <script>
      // Register the @vite-pwa/astro service worker. It is only emitted by the
      // production build, so guard on PROD to avoid a 404 during `astro dev`.
      if (import.meta.env.PROD && "serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          void navigator.serviceWorker.register("/sw.js");
        });
      }
    </script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    /* Solid dark canvas matching the bg-cosmic gradient edge (#0a0e1a) so any
       region the inner gradient can't reach — iOS safe-area insets, the card
       transition reveal — paints dark instead of the white root. */
    background: #0a0e1a;
  }
</style>
