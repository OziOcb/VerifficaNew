---
import "../styles/global.css";
import Banner from "@/components/Banner.astro";
import { missingConfigs } from "@/lib/config-status";

interface Props {
  title?: string;
}

const { title = "Veriffica" } = Astro.props;

// Theme resolver — dark-clamped hook for the future S-10 settings-profile slice.
// Today every value (or no value) resolves to "dark"; S-10 will widen the allowed
// set to {light, dark, system} and add the toggle that writes the `theme` cookie.
function resolveTheme(_value: string | undefined): "dark" {
  return "dark";
}

const theme = resolveTheme(Astro.cookies.get("theme")?.value);
---

<!doctype html>
<html lang="en" class:list={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0a0e1a" />
    <script is:inline>
      // Forward-compatible FOUC guard for S-10's client theme toggle. Mirrors the
      // server-side dark-clamp so server and client never disagree. Must stay a
      // blocking inline script in <head> (not type="module"/deferred) so it runs
      // before <body> paints. Today it just re-asserts "dark".
      (function () {
        document.documentElement.classList.add("dark");
      })();
    </script>
    <title>{title}</title>
  </head>
  <body>
    {
      missingConfigs.map((cfg) => (
        <Banner variant="error">
          <strong>Note:</strong> {cfg.message}
          {cfg.docsUrl && (
            <>
              {" "}
              <a href={cfg.docsUrl} target="_blank" rel="noopener noreferrer">
                {cfg.docsLabel ?? "Documentation"}
              </a>
              .
            </>
          )}
        </Banner>
      ))
    }
    <slot />
    <script>
      // Register the @vite-pwa/astro service worker. It is only emitted by the
      // production build, so guard on PROD to avoid a 404 during `astro dev`.
      if (import.meta.env.PROD && "serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          void navigator.serviceWorker.register("/sw.js");
        });
      }
    </script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    /* Solid dark canvas matching the bg-cosmic gradient edge (#0a0e1a) so any
       region the inner gradient can't reach — iOS safe-area insets, the card
       transition reveal — paints dark instead of the white root. */
    background: #0a0e1a;
  }
</style>
