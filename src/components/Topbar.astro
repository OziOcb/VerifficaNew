---
const { user } = Astro.locals;
---

{/* Transparent bar overlaid on the homepage's dark hero band — light text on the navy backdrop. */}
<div class="flex items-center justify-between text-sm">
  {
    user ? (
      <>
        <span class="text-white/70">{user.email}</span>
        <div class="flex items-center gap-3">
          <a href="/dashboard" class="text-white/90 transition-colors hover:text-white hover:underline">
            Dashboard
          </a>
          <form method="POST" action="/api/auth/signout">
            <button type="submit" class="text-white/90 transition-colors hover:text-white hover:underline">
              Sign out
            </button>
          </form>
        </div>
      </>
    ) : (
      <>
        <span class="text-white/70">Not signed in</span>
        <div class="flex gap-3">
          <a href="/auth/signin" class="text-white/90 transition-colors hover:text-white hover:underline">
            Sign in
          </a>
          <a href="/auth/signup" class="text-white/90 transition-colors hover:text-white hover:underline">
            Sign up
          </a>
        </div>
      </>
    )
  }
</div>
