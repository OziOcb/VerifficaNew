---
import Topbar from "@/components/Topbar.astro";

const { user } = Astro.locals;
---

<div class="bg-background safe-area relative min-h-screen w-full overflow-hidden">
  <div class="relative z-10 p-4 sm:p-8">
    <Topbar />

    <!-- Hero section -->
    <div class="mx-auto flex max-w-4xl flex-col items-center justify-center px-4 py-24 text-center sm:py-32 lg:py-40">
      <span
        class="border-border bg-card text-muted-foreground mb-6 inline-flex items-center rounded-full border px-4 py-1.5 text-sm"
      >
        Your guided used-car inspection
      </span>
      <h1 class="text-foreground mb-6 text-5xl leading-tight font-bold sm:text-6xl lg:text-7xl">
        Inspect a used car like an expert
      </h1>
      <p class="text-muted-foreground mb-10 max-w-2xl text-lg sm:text-xl">
        Veriffica turns the guesswork of buying a used car into a clear, step-by-step checklist — personalized to the
        exact car in front of you and ordered to match how you actually inspect it.
      </p>
      <div class="flex flex-col gap-4 sm:flex-row">
        {
          user ? (
            <a
              href="/dashboard"
              class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex items-center justify-center rounded-lg px-6 py-3 text-base font-medium transition-colors"
            >
              Go to Dashboard
            </a>
          ) : (
            <>
              <a
                href="/auth/signup"
                class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex items-center justify-center rounded-lg px-6 py-3 text-base font-medium transition-colors"
              >
                Register
              </a>
              <a
                href="/auth/signin"
                class="border-border text-foreground hover:bg-accent hover:text-accent-foreground inline-flex items-center justify-center rounded-lg border px-6 py-3 text-base font-medium transition-colors"
              >
                Sign in
              </a>
            </>
          )
        }
      </div>
    </div>

    <!-- Personalization wedge -->
    <div class="mx-auto max-w-4xl px-4 pb-16 sm:pb-24">
      <div class="border-border bg-card rounded-2xl border p-8 sm:p-12">
        <h2 class="text-foreground mb-4 text-2xl font-bold sm:text-3xl">A checklist that already knows your car</h2>
        <p class="text-muted-foreground max-w-3xl text-base leading-relaxed sm:text-lg">
          You tell Veriffica the car's fuel type, transmission, drive, body type and a few equipment details. From that,
          it builds a question set tailored to <span class="text-foreground font-semibold">this specific car</span> — never
          a wall of generic questions about features the car doesn't have. You only see what's relevant to the vehicle in
          front of you.
        </p>
      </div>
    </div>

    <!-- 5-part overview -->
    <div class="mx-auto max-w-5xl px-4 pb-16 sm:pb-24">
      <div class="mb-10 text-center">
        <h2 class="text-foreground mb-3 text-2xl font-bold sm:text-3xl">Your inspection, in five parts</h2>
        <p class="text-muted-foreground mx-auto max-w-2xl text-base">
          Questions are arranged in the real-world order of a physical inspection, so you move through the car the way
          an expert would.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-5">
        <!-- 1. Info -->
        <div class="border-border bg-card rounded-xl border p-6">
          <div class="mb-4 flex items-center gap-3">
            <svg
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-primary"
            >
              <rect width="8" height="4" x="8" y="2" rx="1" ry="1"></rect>
              <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
              <path d="M12 11h4"></path>
              <path d="M12 16h4"></path>
              <path d="M8 11h.01"></path>
              <path d="M8 16h.01"></path>
            </svg>
            <span class="text-muted-foreground text-xs font-medium tracking-wider uppercase">Part 1</span>
          </div>
          <h3 class="text-foreground mb-2 text-lg font-semibold">Info</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">
            Describe the car's configuration so the checklist can personalize itself to the vehicle.
          </p>
        </div>

        <!-- 2. Standstill -->
        <div class="border-border bg-card rounded-xl border p-6">
          <div class="mb-4 flex items-center gap-3">
            <svg
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-primary"
            >
              <path
                d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"
              ></path>
              <circle cx="7" cy="17" r="2"></circle>
              <path d="M9 17h6"></path>
              <circle cx="17" cy="17" r="2"></circle>
            </svg>
            <span class="text-muted-foreground text-xs font-medium tracking-wider uppercase">Part 2</span>
          </div>
          <h3 class="text-foreground mb-2 text-lg font-semibold">Standstill</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">
            Check the bodywork, tyres, and exterior with the car parked and the engine off.
          </p>
        </div>

        <!-- 3. Engine -->
        <div class="border-border bg-card rounded-xl border p-6">
          <div class="mb-4 flex items-center gap-3">
            <svg
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-primary"
            >
              <path d="M12 2v10"></path>
              <path d="M18.4 6.6a9 9 0 1 1-12.77.04"></path>
            </svg>
            <span class="text-muted-foreground text-xs font-medium tracking-wider uppercase">Part 3</span>
          </div>
          <h3 class="text-foreground mb-2 text-lg font-semibold">Engine</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">
            Start the engine and watch, listen, and check for the signs that matter cold and warm.
          </p>
        </div>

        <!-- 4. Drive -->
        <div class="border-border bg-card rounded-xl border p-6">
          <div class="mb-4 flex items-center gap-3">
            <svg
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-primary"
            >
              <circle cx="6" cy="19" r="3"></circle>
              <path d="M9 19h8.5a3.5 3.5 0 0 0 0-7h-11a3.5 3.5 0 0 1 0-7H15"></path>
              <circle cx="18" cy="5" r="3"></circle>
            </svg>
            <span class="text-muted-foreground text-xs font-medium tracking-wider uppercase">Part 4</span>
          </div>
          <h3 class="text-foreground mb-2 text-lg font-semibold">Drive</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">
            Take it for a test drive and assess how it behaves on the road, under load and braking.
          </p>
        </div>

        <!-- 5. Documents -->
        <div class="border-border bg-card rounded-xl border p-6">
          <div class="mb-4 flex items-center gap-3">
            <svg
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-primary"
            >
              <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path>
              <path d="M14 2v4a2 2 0 0 0 2 2h4"></path>
              <path d="M16 13H8"></path>
              <path d="M16 17H8"></path>
              <path d="M10 9H8"></path>
            </svg>
            <span class="text-muted-foreground text-xs font-medium tracking-wider uppercase">Part 5</span>
          </div>
          <h3 class="text-foreground mb-2 text-lg font-semibold">Documents</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">
            Verify the paperwork, service history, and identifiers before you commit to the purchase.
          </p>
        </div>
      </div>
    </div>

    <!-- Why Veriffica -->
    <div class="mx-auto max-w-4xl px-4 pb-16 sm:pb-24">
      <h2 class="text-foreground mb-10 text-center text-2xl font-bold sm:text-3xl">Why Veriffica</h2>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
        <div class="border-border bg-card rounded-xl border p-6">
          <svg
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-primary mb-4"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <circle cx="12" cy="12" r="6"></circle>
            <circle cx="12" cy="12" r="2"></circle>
          </svg>
          <h3 class="text-foreground mb-2 text-lg font-semibold">Personalized to your car</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">
            Only the questions that apply to this car's configuration — no noise, no irrelevant checks.
          </p>
        </div>

        <div class="border-border bg-card rounded-xl border p-6">
          <svg
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-primary mb-4"
          >
            <path d="M11 12H3"></path>
            <path d="m15 16 4-4-4-4"></path>
            <path d="M19 12H11"></path>
            <path d="M3 6v12"></path>
          </svg>
          <h3 class="text-foreground mb-2 text-lg font-semibold">In the right order</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">
            Questions follow the real flow of an inspection, so you never double back or miss a step.
          </p>
        </div>

        <div class="border-border bg-card rounded-xl border p-6">
          <svg
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-primary mb-4"
          >
            <path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"
            ></path>
            <path d="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7"></path>
            <path d="M7 3v4a1 1 0 0 0 1 1h7"></path>
          </svg>
          <h3 class="text-foreground mb-2 text-lg font-semibold">Nothing forgotten</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">
            Every answer and note is recorded as you go, so the full picture is there when you decide.
          </p>
        </div>
      </div>
    </div>

    <!-- Helper-tool disclaimer -->
    <div class="mx-auto max-w-4xl px-4 pb-24">
      <div class="border-border bg-card rounded-xl border p-6 text-center">
        <p class="text-muted-foreground text-sm leading-relaxed">
          Veriffica is a helper tool that structures your inspection — it does not replace a professional technical
          inspection.
        </p>
      </div>
    </div>
  </div>
</div>
