---
import Topbar from "@/components/Topbar.astro";

const { user } = Astro.locals;
---

<div class="bg-cosmic safe-area relative min-h-screen w-full overflow-hidden">
  <!-- Cosmic orbs -->
  <div
    class="pointer-events-none absolute top-1/4 -left-24 h-[350px] w-[350px] rounded-full bg-purple-500/20 blur-[120px]"
  >
  </div>
  <div
    class="pointer-events-none absolute top-2/3 -right-16 h-[250px] w-[250px] rounded-full bg-blue-500/15 blur-[100px]"
  >
  </div>
  <div
    class="pointer-events-none absolute top-0 left-1/2 h-[300px] w-[300px] -translate-x-1/2 rounded-full bg-indigo-400/10 blur-[140px]"
  >
  </div>

  <!-- Star field -->
  <div
    class="pointer-events-none absolute inset-0"
    style="background-image: radial-gradient(circle, rgba(255,255,255,0.15) 1px, transparent 1px), radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px), radial-gradient(circle, rgba(255,255,255,0.07) 1px, transparent 1px); background-size: 200px 200px, 150px 150px, 100px 100px; background-position: 0 0, 40px 60px, 80px 30px;"
  >
  </div>

  <div class="relative z-10 p-4 sm:p-8">
    <Topbar />

    <!-- Hero section -->
    <div class="mx-auto flex max-w-4xl flex-col items-center justify-center px-4 py-24 text-center sm:py-32 lg:py-40">
      <span
        class="mb-6 inline-flex items-center rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-sm text-blue-100/70 backdrop-blur-xl"
      >
        Your guided used-car inspection
      </span>
      <h1
        class="mb-6 bg-gradient-to-r from-blue-200 via-purple-200 to-pink-200 bg-clip-text text-5xl leading-tight font-bold text-transparent sm:text-6xl lg:text-7xl"
      >
        Inspect a used car like an expert
      </h1>
      <p class="mb-10 max-w-2xl text-lg text-blue-100/70 sm:text-xl">
        Veriffica turns the guesswork of buying a used car into a clear, step-by-step checklist — personalized to the
        exact car in front of you and ordered to match how you actually inspect it.
      </p>
      <div class="flex flex-col gap-4 sm:flex-row">
        {
          user ? (
            <a
              href="/dashboard"
              class="inline-flex items-center justify-center rounded-lg bg-purple-600 px-6 py-3 text-base font-medium text-white transition-colors hover:bg-purple-500"
            >
              Go to Dashboard
            </a>
          ) : (
            <>
              <a
                href="/auth/signup"
                class="inline-flex items-center justify-center rounded-lg bg-purple-600 px-6 py-3 text-base font-medium text-white transition-colors hover:bg-purple-500"
              >
                Register
              </a>
              <a
                href="/auth/signin"
                class="inline-flex items-center justify-center rounded-lg border border-white/20 px-6 py-3 text-base font-medium text-white transition-colors hover:bg-white/10"
              >
                Sign in
              </a>
            </>
          )
        }
      </div>
    </div>

    <!-- Personalization wedge -->
    <div class="mx-auto max-w-4xl px-4 pb-16 sm:pb-24">
      <div
        class="rounded-2xl border border-white/10 bg-gradient-to-br from-purple-500/10 to-blue-500/5 p-8 backdrop-blur-xl sm:p-12"
      >
        <h2 class="mb-4 text-2xl font-bold text-white sm:text-3xl">A checklist that already knows your car</h2>
        <p class="max-w-3xl text-base leading-relaxed text-blue-100/70 sm:text-lg">
          You tell Veriffica the car's fuel type, transmission, drive, body type and a few equipment details. From that,
          it builds a question set tailored to <span class="font-semibold text-white">this specific car</span> — never a wall
          of generic questions about features the car doesn't have. You only see what's relevant to the vehicle in front of
          you.
        </p>
      </div>
    </div>

    <!-- 5-part overview -->
    <div class="mx-auto max-w-5xl px-4 pb-16 sm:pb-24">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-2xl font-bold text-white sm:text-3xl">Your inspection, in five parts</h2>
        <p class="mx-auto max-w-2xl text-base text-blue-100/60">
          Questions are arranged in the real-world order of a physical inspection, so you move through the car the way
          an expert would.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-5">
        <!-- 1. Info -->
        <div class="rounded-xl border border-white/10 bg-white/5 p-6 backdrop-blur-xl">
          <div class="mb-4 flex items-center gap-3">
            <svg
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-purple-300"
            >
              <rect width="8" height="4" x="8" y="2" rx="1" ry="1"></rect>
              <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
              <path d="M12 11h4"></path>
              <path d="M12 16h4"></path>
              <path d="M8 11h.01"></path>
              <path d="M8 16h.01"></path>
            </svg>
            <span class="text-xs font-medium tracking-wider text-blue-100/40 uppercase">Part 1</span>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-white">Info</h3>
          <p class="text-sm leading-relaxed text-blue-100/60">
            Describe the car's configuration so the checklist can personalize itself to the vehicle.
          </p>
        </div>

        <!-- 2. Standstill -->
        <div class="rounded-xl border border-white/10 bg-white/5 p-6 backdrop-blur-xl">
          <div class="mb-4 flex items-center gap-3">
            <svg
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-purple-300"
            >
              <path
                d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"
              ></path>
              <circle cx="7" cy="17" r="2"></circle>
              <path d="M9 17h6"></path>
              <circle cx="17" cy="17" r="2"></circle>
            </svg>
            <span class="text-xs font-medium tracking-wider text-blue-100/40 uppercase">Part 2</span>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-white">Standstill</h3>
          <p class="text-sm leading-relaxed text-blue-100/60">
            Check the bodywork, tyres, and exterior with the car parked and the engine off.
          </p>
        </div>

        <!-- 3. Engine -->
        <div class="rounded-xl border border-white/10 bg-white/5 p-6 backdrop-blur-xl">
          <div class="mb-4 flex items-center gap-3">
            <svg
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-purple-300"
            >
              <path d="M12 2v10"></path>
              <path d="M18.4 6.6a9 9 0 1 1-12.77.04"></path>
            </svg>
            <span class="text-xs font-medium tracking-wider text-blue-100/40 uppercase">Part 3</span>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-white">Engine</h3>
          <p class="text-sm leading-relaxed text-blue-100/60">
            Start the engine and watch, listen, and check for the signs that matter cold and warm.
          </p>
        </div>

        <!-- 4. Drive -->
        <div class="rounded-xl border border-white/10 bg-white/5 p-6 backdrop-blur-xl">
          <div class="mb-4 flex items-center gap-3">
            <svg
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-purple-300"
            >
              <circle cx="6" cy="19" r="3"></circle>
              <path d="M9 19h8.5a3.5 3.5 0 0 0 0-7h-11a3.5 3.5 0 0 1 0-7H15"></path>
              <circle cx="18" cy="5" r="3"></circle>
            </svg>
            <span class="text-xs font-medium tracking-wider text-blue-100/40 uppercase">Part 4</span>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-white">Drive</h3>
          <p class="text-sm leading-relaxed text-blue-100/60">
            Take it for a test drive and assess how it behaves on the road, under load and braking.
          </p>
        </div>

        <!-- 5. Documents -->
        <div class="rounded-xl border border-white/10 bg-white/5 p-6 backdrop-blur-xl">
          <div class="mb-4 flex items-center gap-3">
            <svg
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-purple-300"
            >
              <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path>
              <path d="M14 2v4a2 2 0 0 0 2 2h4"></path>
              <path d="M16 13H8"></path>
              <path d="M16 17H8"></path>
              <path d="M10 9H8"></path>
            </svg>
            <span class="text-xs font-medium tracking-wider text-blue-100/40 uppercase">Part 5</span>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-white">Documents</h3>
          <p class="text-sm leading-relaxed text-blue-100/60">
            Verify the paperwork, service history, and identifiers before you commit to the purchase.
          </p>
        </div>
      </div>
    </div>

    <!-- Why Veriffica -->
    <div class="mx-auto max-w-4xl px-4 pb-16 sm:pb-24">
      <h2 class="mb-10 text-center text-2xl font-bold text-white sm:text-3xl">Why Veriffica</h2>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
        <div class="rounded-xl border border-white/10 bg-white/5 p-6 backdrop-blur-xl">
          <svg
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="mb-4 text-purple-300"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <circle cx="12" cy="12" r="6"></circle>
            <circle cx="12" cy="12" r="2"></circle>
          </svg>
          <h3 class="mb-2 text-lg font-semibold text-white">Personalized to your car</h3>
          <p class="text-sm leading-relaxed text-blue-100/60">
            Only the questions that apply to this car's configuration — no noise, no irrelevant checks.
          </p>
        </div>

        <div class="rounded-xl border border-white/10 bg-white/5 p-6 backdrop-blur-xl">
          <svg
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="mb-4 text-purple-300"
          >
            <path d="M11 12H3"></path>
            <path d="m15 16 4-4-4-4"></path>
            <path d="M19 12H11"></path>
            <path d="M3 6v12"></path>
          </svg>
          <h3 class="mb-2 text-lg font-semibold text-white">In the right order</h3>
          <p class="text-sm leading-relaxed text-blue-100/60">
            Questions follow the real flow of an inspection, so you never double back or miss a step.
          </p>
        </div>

        <div class="rounded-xl border border-white/10 bg-white/5 p-6 backdrop-blur-xl">
          <svg
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="mb-4 text-purple-300"
          >
            <path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"
            ></path>
            <path d="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7"></path>
            <path d="M7 3v4a1 1 0 0 0 1 1h7"></path>
          </svg>
          <h3 class="mb-2 text-lg font-semibold text-white">Nothing forgotten</h3>
          <p class="text-sm leading-relaxed text-blue-100/60">
            Every answer and note is recorded as you go, so the full picture is there when you decide.
          </p>
        </div>
      </div>
    </div>

    <!-- Helper-tool disclaimer -->
    <div class="mx-auto max-w-4xl px-4 pb-24">
      <div class="rounded-xl border border-white/10 bg-white/5 p-6 text-center backdrop-blur-xl">
        <p class="text-sm leading-relaxed text-blue-100/50">
          Veriffica is a helper tool that structures your inspection — it does not replace a professional technical
          inspection.
        </p>
      </div>
    </div>
  </div>
</div>
