---
import camelcaseKeys from "camelcase-keys";
import Layout from "@/layouts/Layout.astro";
import DashboardBoard from "@/components/dashboard/DashboardBoard";
import AccountMenu from "@/components/dashboard/AccountMenu";
import { createClient } from "@/lib/supabase";
import type { Inspection } from "@/lib/inspections";

// SSR read surface (NOT offline-first): fetch this owner's inspections under RLS
// at render — exactly like middleware's server client — then convert the
// snake_case rows to camelCase at this single boundary (lessons.md "Field
// casing") before handing them to the island. This frontmatter must never import
// @/lib/db / @/lib/sync (Dexie has no global on workerd).
const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);

let inspections: Inspection[] = [];
let configured = true;
if (supabase) {
  const { data } = await supabase
    .from("inspections")
    .select("id,status,name,created_at,updated_at")
    .order("created_at", { ascending: false });
  inspections = camelcaseKeys(data ?? [], { deep: true });
} else {
  configured = false;
}
---

<Layout title="Dashboard">
  {/* Themed shell — matches the public home page (Home.astro). */}
  <div class="bg-background safe-area relative min-h-screen w-full">
    <div class="relative z-10 p-4 sm:p-8">
      {
        configured ? (
          <div class="mx-auto max-w-3xl">
            <div class="mb-4 flex items-center justify-between px-1">
              <span class="text-foreground text-lg font-semibold">Veriffica</span>
              <AccountMenu client:only="react" userEmail={user?.email} />
            </div>
            <DashboardBoard client:load inspections={inspections} userId={user?.id ?? ""} />
          </div>
        ) : (
          <div class="border-border bg-card text-muted-foreground mx-auto max-w-3xl rounded-xl border p-6 text-center">
            Supabase is not configured. Set SUPABASE_URL / SUPABASE_KEY to continue.
          </div>
        )
      }
    </div>
  </div>
</Layout>
