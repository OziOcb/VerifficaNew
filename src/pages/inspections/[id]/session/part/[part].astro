---
import camelcaseKeys from "camelcase-keys";
import Layout from "@/layouts/Layout.astro";
import Part1Form from "@/components/inspections/Part1Form";
import QuestionCards from "@/components/inspections/QuestionCards";
import { createClient } from "@/lib/supabase";
import { isConfigUnlocked, rowToInput } from "@/lib/part1-config";
import {
  activeFlagsFromInspection,
  configFromInspection,
  relevantTogglesByFuel,
  selectCardDeck,
  visibleCountsByPart,
} from "@/lib/questions";
import type { AnswersMap } from "@/lib/answers";
import { isValidPart, resolvePartScreen } from "@/lib/session-routes";

// Per-Part screens under the session hub (S-04). Part 1 IS the Part 1 config form
// (the existing island); Parts 2–5 are placeholders until S-05 builds the question
// cards. The route + SSR-load + visibility contract here stay; S-05 swaps the body.
const { id, part } = Astro.params;

// Valid parts are 1–5; anything else is not a real screen → back to the dashboard.
// Names + order are the PRD's five parts (prd.md:56), in physical-inspection order.
const PART_TITLES: Record<string, string> = {
  "1": "Info",
  "2": "Standstill",
  "3": "Engine",
  "4": "Drive",
  "5": "Documents",
};
// Unknown part is not a real screen → dashboard (before any DB work).
if (!isValidPart(part)) {
  return Astro.redirect("/dashboard");
}

const supabase = createClient(Astro.request.headers, Astro.cookies);
const { data: row } = supabase
  ? await supabase
      .from("inspections")
      .select(
        "id,name,status,created_at,price,make,model,year,registration_number,vin,mileage,fuel_type,transmission,drive,color,body_type,door_count,address,notes,global_notes,charging_port_equipped,ev_battery_docs_available,turbo_equipped,mechanical_compressor_equipped,imported_from_eu,answers",
      )
      .eq("id", id ?? "")
      .maybeSingle()
  : { data: null };

// Absent row (RLS hid a foreign/missing id → null) → dashboard. The early return also
// narrows `inspection` to non-null for the render path below (no cast needed).
if (!row) {
  return Astro.redirect("/dashboard");
}
// Single snake→camel boundary (lessons.md "Field casing"). `stopPaths: ["answers"]`
// excludes the jsonb answers map from the deep transform so its opaque `q_…` question-ID
// keys survive verbatim — camelizing them would break the catalogue lookup (Phase 1).
const inspection = camelcaseKeys(row, { deep: true, stopPaths: ["answers"] });
const unlocked = isConfigUnlocked(rowToInput(inspection));

// Parts 2–5 require a valid config; otherwise back to Part 1 (the only place to make it
// valid). Part 1 is always reachable. The screen decision is unit-tested in session-routes.
const screen = resolvePartScreen({ id: id ?? "", part, unlocked });
if ("redirect" in screen) {
  return Astro.redirect(screen.redirect);
}

// The FR-014 engine runs HERE (server-side, with the 80 KB catalogue): for Parts 2–5 build
// the ordered, personalized card deck + per-Part count, honoring the persisted equipment
// flags so it matches what the session nav shows after a toggle. Only the filtered deck +
// the answers map cross to the `client:only` island — the catalogue never ships.
let visibleCount = 0;
let cards: ReturnType<typeof selectCardDeck> = [];
let initialAnswers: AnswersMap = {};
if (part !== "1") {
  const config = configFromInspection(inspection);
  const flags = activeFlagsFromInspection(inspection);
  visibleCount = visibleCountsByPart(config, flags)[`part${part}`];
  cards = selectCardDeck(config, flags, `part${part}`);
  // Read the answers off the RAW snake_case `row`, not the camelized `inspection`: `answers`
  // is jsonb typed `Json`, and forcing the deep camel transform to instantiate over Json's
  // recursive union blows the type checker up (ts2589). `answers` is a single word, so casing
  // is moot — its verbatim `q_…` keys are preserved by the `stopPaths` boundary above.
  initialAnswers = (row.answers ?? {}) as AnswersMap;
}

// Part 1 hosts the equipment toggles (FR-014): the catalogue-derived relevance map, keyed
// by fuelType, lets the form pick relevant toggles from its live selection without the
// catalogue. Computed here (server-side); only the small map crosses to the island.
const relevantTogglesMap = relevantTogglesByFuel();
---

{
  part === "1" ? (
    <Layout title="Part 1 — Vehicle configuration">
      <div class="bg-background safe-area min-h-screen w-full">
        <main class="mx-auto max-w-3xl p-4 sm:p-8">
          <Part1Form client:only="react" inspection={inspection} relevantTogglesByFuel={relevantTogglesMap} />
        </main>
      </div>
    </Layout>
  ) : (
    <Layout title={`Part ${part} — ${PART_TITLES[part]}`}>
      <div class="bg-background safe-area min-h-screen w-full">
        <main class="mx-auto max-w-3xl space-y-8 p-4 sm:p-8">
          <header>
            <a
              href={`/inspections/${id ?? ""}/session`}
              class="text-primary hover:text-primary/80 text-sm transition-colors hover:underline"
            >
              &larr; Back to session
            </a>
            <p class="text-muted-foreground mt-4 text-xs tracking-wider uppercase">Part {part}</p>
            <h1 class="text-foreground mt-1 text-2xl font-bold">{PART_TITLES[part]}</h1>
            <p class="text-muted-foreground mt-1">
              {`${visibleCount} ${visibleCount === 1 ? "question" : "questions"} for this car.`}
            </p>
          </header>

          <QuestionCards
            client:only="react"
            id={id ?? ""}
            cards={cards}
            initialAnswers={initialAnswers}
            initialGlobalNotes={inspection.globalNotes ?? ""}
            partLabel={`Part ${part} — ${PART_TITLES[part]}`}
          />
        </main>
      </div>
    </Layout>
  )
}
