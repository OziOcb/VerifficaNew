# @vite-pwa/astro 1.2.0 (latest) caps its Astro peer at v5, but this project runs
# Astro 6. The integration is a thin wrapper over vite-plugin-pwa and works on
# Astro 6 (verified: build emits sw.js + precache manifest). Relax peer resolution
# so the default `npm install` (and CI) succeeds without a per-command flag.
legacy-peer-deps=true
